{
  "name": "starlight-llm-actions",
  "version": "0.2.1",
  "type": "module",
  "description": "Starlight plugin: Page Actions dropdown with Copy/View/PDF and Open-in-LLM buttons (ChatGPT, Claude, Gemini, Perplexity, T3 Chat, Cursor, Copilot).",
  "license": "MIT",
  "author": "Holden Hewett",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdenhewett/starlight-llm-actions.git",
    "directory": "packages/starlight-llm-actions"
  },
  "homepage": "https://holdenhewett.github.io/starlight-llm-actions/",
  "bugs": {
    "url": "https://github.com/holdenhewett/starlight-llm-actions/issues"
  },
  "keywords": [
    "astro-integration",
    "astro-component",
    "withastro",
    "starlight",
    "starlight-plugin",
    "astro",
    "documentation",
    "llm",
    "ai",
    "chatgpt",
    "claude",
    "gemini",
    "perplexity",
    "cursor",
    "page-actions",
    "copy-as-markdown",
    "open-in-chatgpt"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noCheck && node scripts/copy-assets.mjs",
    "dev": "tsc -p tsconfig.build.json --noCheck --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./route": "./dist/route.ts",
    "./overrides/PageTitle.astro": "./dist/overrides/PageTitle.astro"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@astrojs/starlight": ">=0.36.0",
    "astro": ">=5.6.0",
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "engines": {
    "node": "^22.0.0 || >=24.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
