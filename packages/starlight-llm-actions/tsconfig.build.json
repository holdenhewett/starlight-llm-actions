{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "schema.ts",
    "config/**/*.ts",
    "internal/**/*.ts",
    "providers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "env.d.ts",
    "route.ts",
    "**/*.astro",
    "**/*.test.ts"
  ]
}
